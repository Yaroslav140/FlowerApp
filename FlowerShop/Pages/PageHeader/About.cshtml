@page
@model FlowerShop.Web.Pages.PageHeader.AboutModel
@section Styles {
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
}

<div class="home-container">
    <div class="content__about">
        <span class="hero__badge">🌿 О нашей компании</span>
        <h1 class="content__main">О Flower&Shop</h1>
        <div class="container-content__description">
            <p class="content__description">
                Flower&Shop был основан в 2015 году с простой идеей: приносить радость через красоту природы.
                Каждый букет создается вручную нашими опытными флористами с особым вниманием к деталям.
                Мы выбираем только самые свежие цветы от проверенных поставщиков и работаем с любовью,
                чтобы каждый заказ стал незабываемым подарком. Наша миссия — сделать мир немного ярче,
                один букет за другим.
            </p>
            <div class="features-grid">
                <div class="feature-card">
                    <img src="~/img/flower-icon-about.png" alt="Свежие цветы" />
                    <h2>Свежие цветы</h2>
                    <p>Ежедневные поставки</p>
                </div>

                <div class="feature-card">
                    <img src="~/img/hand-icon-about.png" alt="Ручная работа" />
                    <h2>Ручная работа</h2>
                    <p>Каждый букет уникален</p>
                </div>

                <div class="feature-card">
                    <img src="~/img/shipped-icon-about.png" alt="Доставка" />
                    <h2>Быстрая доставка</h2>
                    <p>В день заказа</p>
                </div>
            </div>
        </div>
        <div class="feedback-container">
            <img class="feedback-container__img" src="/img/star-icon-about.png" />
            <h1 class="feedback-container__title">Что говорят наши клиенты</h1>
            <p class="feedback-container__description">Узнайте о впечатлениях других покупателей и поделитесь своим опытом</p>
            <a class="feedback-container__btn" asp-page="/Feedbacks">
                <img src="/img/chat-icno-about.svg" alt="Чат"/>
                Читать отзывы
            </a>
        </div>
    </div>
</div>
