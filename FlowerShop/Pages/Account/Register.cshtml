@page
@model FlowerShop.Web.Pages.Account.RegisterModel

@section Styles {
    <link rel="stylesheet" href="~/css/authorization.css" asp-append-version="true" />
}

<div class="auth-center">
    <div class="form-card">
        <span class="hero-badge">
            <img src="/img/star-icon-authorization.png" />
        </span>
        <h2>Создание аккаунта</h2>
        <p class="subtitle">Присоединяйтесь к нам, чтобы начать заказывать<br /> красивые цветы</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert error"></div>

            <div class="form-group">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" class="form-control" placeholder="Введите имя пользователя" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Login"></label>
                <input asp-for="Login" class="form-control" placeholder="Введите логин" />
                <span asp-validation-for="Login" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Введите пароль" />
                <input type="text" name="WebSite" id="WebSite" tabindex="-1" autocomplete="off" style="position: absolute; left: -9999px; opacity: 0;" placeholder="Website" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Повторите пароль" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="submit-btn">Зарегистрироваться</button>
        </form>

        <div class="signin">
            У вас уже есть учетная запись? <a href="/Account/Login">Sign In</a>
        </div>
    </div>
</div>
