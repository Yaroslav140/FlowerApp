@page "{id:guid}"
@using FlowerShop.Data.Models
@model FlowerShop.Web.Pages.Account.ViewOrderDetailsModel
@{
    var order = Model.Order;
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

@section Styles {
    <link rel="stylesheet" href="/css/account-view-order-details.css" asp-append-version="true" />
}

@if (order is null)
{
    <div class="container center">Заказ не найден.</div>
}
else
{
    <div class="container">
        <div asp-validation-summary="ModelOnly" class="error"></div>

        <a href="/Account/Profile" class="back-link">
            <span>←</span> Вернуться к профилю
        </a>

        <header class="page-title-row">
            <h1 class="page-title">Заказ #@order.Id.ToString().Substring(order.Id.ToString().Length - 4)</h1>
            <div class="order-meta">
                <span>Дата заказа: @order.PickupDate.ToString("dd.MM.yyyy")</span>
                @switch (order.Status)
                {
                    case OrderStatus.New:
                        <span class="status-text" style="background: #78df7f;">Новый</span>
                        break;
                    case OrderStatus.Pending:
                        <span class="status-text" style="background: #f89e00;">Ожидает</span>
                        break;
                    case OrderStatus.InProgress:
                        <span class="status-text" style="background: #00ade4;">В обработке</span>
                        break;
                    case OrderStatus.Completed:
                        <span class="status-text" style="background: #00c857;">Выполнен</span>
                        break;
                    case OrderStatus.Cancelled:
                        <span class="status-text" style="background: #eb0a0a;">Отменён</span>
                        break;
                    default:
                        <span class="status-text">@order.Status</span>
                        break;
                }
            </div>
        </header>

        <div class="order-layout">
            <main>
                <section class="card">
                    <div class="card-header">Состав заказа</div>

                    @if (order.OrderItem != null)
                    {
                        <div class="order-items-container">
                            @foreach (var item in order.OrderItem)
                            {
                                var lineTotal = item.Price * item.Quantity;
                                var name = item.Bouquet?.Name ?? item.SoftToy?.Name ?? "Неизвестный товар";
                                string itemImage = "";

                                if (item.Bouquet != null)
                                {
                                    itemImage = !string.IsNullOrEmpty(item.Bouquet.ImagePath)
                                    ? item.Bouquet.ImagePath
                                    : "/uploads/bouquets/Empty.png";
                                }
                                else if (item.SoftToy != null)
                                {
                                    itemImage = !string.IsNullOrEmpty(item.SoftToy.ImagePath)
                                    ? item.SoftToy.ImagePath
                                    : "/uploads/softToys/Empty.png";
                                }

                                <article class="item-block">
                                    <img src="@itemImage" alt="@name" class="item-block__image" />
                                    <div class="item-block__info">
                                        <div class="item-block__title">@name</div>
                                        <div class="item-block__qty">Количество: @item.Quantity шт</div>
                                        <div class="item-block__price">
                                            @item.Price.ToString("C", culture) × @item.Quantity = @lineTotal.ToString("C", culture)
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }

                    @if (order.Status != OrderStatus.Cancelled && order.Status != OrderStatus.Completed)
                    {
                        <div class="add-product">
                            <h4 class="add-product__title">Добавить товар в заказ</h4>
                            <a href="#catalog-modal" class="btn">
                                + Выбрать товар из каталога
                            </a>
                        </div>
                    }
                </section>
            </main>

            <aside>
                <section class="card" id="deliveryInfo">
                    <div class="card-header">Информация о доставке</div>

                    <div class="address-block">
                        <div class="label">Адрес доставки</div>

                        @if (Model.IsEditingAddress)
                        {
                            <form method="post" asp-page-handler="UpdateAddress" asp-route-id="@Model.Order.Id" class="address-edit-form">
                                <input type="text" asp-for="NewDeliveryAddress" class="address-edit-input" placeholder="Введите адрес" />
                                <div class="address-edit-actions">
                                    <button type="submit" class="addr-btn addr-btn--confirm" title="Сохранить">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <a class="addr-btn addr-btn--cancel"
                                       asp-page="./ViewOrderDetails"
                                       asp-route-id="@Model.Order.Id"
                                       asp-fragment="deliveryInfo"
                                       title="Отмена">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </a>
                                </div>
                                <span asp-validation-for="NewDeliveryAddress" class="text-danger small"></span>
                            </form>
                        }
                        else
                        {
                            <div class="address-view">
                                <div class="value-text">@Model.Order.DeliveryAddress</div>
                                <a asp-page="./ViewOrderDetails"
                                   asp-route-id="@Model.Order.Id"
                                   asp-route-editAddress="true"
                                   asp-fragment="deliveryInfo"
                                   class="address-edit-link">
                                    <img src="/img/edit-icon.png" style="width: 20px; height: 20px;" />
                                </a>
                            </div>
                        }
                    </div>

                    <div class="address-block" style="margin-bottom:0;">
                        <div class="label">Дата и время</div>
                        <div class="value-text">
                            @order.PickupDate.ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-header">Итого</div>

                    <div class="summary-line">
                        <span>Товары (@order.OrderItem?.Count шт)</span>
                        <span style="font-weight:600;">@order.TotalAmount.ToString("C", culture)</span>
                    </div>

                    <div class="summary-line">
                        <span>Доставка</span>
                        <span class="text-free">Бесплатно</span>
                    </div>

                    <div class="total-line">
                        <span class="total-label">Всего</span>
                        <span class="total-value">@order.TotalAmount.ToString("C", culture)</span>
                    </div>
                </section>

                @if (order.Status != OrderStatus.Completed && order.Status != OrderStatus.Cancelled)
                {
                    <form method="post" class="mt-3">
                        <button type="submit" asp-page-handler="CancelOrder" asp-route-id="@order.Id"
                                class="btn--outline-pink w-100"
                                onclick="return confirm('Вы уверены, что хотите отменить заказ?');">
                            Отменить заказ
                        </button>
                    </form>
                }
                else if (order.Status == OrderStatus.Cancelled)
                {
                    <div class="alert alert-danger mt-3 text-center">Заказ отменён</div>
                }

                <a href="/PageHeader/Contacts" class="btn-support mt-3">
                    <img src="~/img/chat-icno-about.svg" style="width:20px;filter: brightness(0) invert(1);" alt="" />
                    Связаться с поддержкой
                </a>
            </aside>
        </div>
    </div>

    @if (order.Status != OrderStatus.Cancelled && order.Status != OrderStatus.Completed)
    {
        <div id="catalog-modal" class="catalog-overlay">
            <a asp-page="./ViewOrderDetails" asp-route-id="@order.Id" class="catalog-backdrop"></a>

            <div class="catalog-dialog">
                <div class="catalog-header">
                    <span class="catalog-title">Выбрать товар</span>
                    <a asp-page="./ViewOrderDetails" asp-route-id="@order.Id" class="catalog-close">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </a>
                </div>

                <div class="catalog-search-wrap">
                    <svg class="catalog-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="text" class="catalog-search-input" placeholder="Поиск товаров..."
                           oninput="document.querySelectorAll('.pc').forEach(c=>{c.style.display=this.value&&!c.dataset.name.toLowerCase().includes(this.value.toLowerCase())?'none':''})" />
                </div>

                <div class="catalog-tabs-wrap">
                    <input type="radio" name="cat-tab" id="ct-all" class="ct-radio" checked>
                    <label for="ct-all" class="ct-label">Все товары</label>
                    <input type="radio" name="cat-tab" id="ct-bouq" class="ct-radio">
                    <label for="ct-bouq" class="ct-label">Букеты</label>
                    <input type="radio" name="cat-tab" id="ct-toys" class="ct-radio">
                    <label for="ct-toys" class="ct-label">Игрушки</label>
                </div>

                <div class="catalog-grid-wrap">
                    <div class="catalog-grid">
                        @foreach (var b in Model.Bouquets)
                        {
                            <div class="pc pc-bouq" data-name="@b.Name">
                                <div class="pc-img-wrap">
                                    <img src="@(!string.IsNullOrEmpty(b.ImagePath) ? b.ImagePath : "/uploads/bouquets/Empty.png")"
                                         alt="@b.Name" class="pc-img" />
                                </div>
                                <div class="pc-body">
                                    <div class="pc-name">@b.Name</div>
                                    <div class="pc-desc">@b.Description</div>
                                    <div class="pc-footer">
                                        <span class="pc-price">@b.Price.ToString("C", culture)</span>
                                        <span class="pc-rating">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="#f5a623" stroke="#f5a623" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                            <p>@(b.Rating > 1 ? (b.Rating % 1 == 0 ? b.Rating.ToString("F0") : b.Rating.ToString("F1")) : "5")</p>
                                        </span>
                                    </div>
                                    <form method="post" asp-page-handler="AddProduct">
                                        <input type="hidden" name="SelectedProductId" value="@b.BouquetId" />
                                        <input type="hidden" name="ProductType" value="bouquet" />
                                        <button type="submit" class="pc-add-btn">+ Добавить</button>
                                    </form>
                                </div>
                            </div>
                        }
                        @foreach (var t in Model.SoftToys)
                        {
                            <div class="pc pc-toy" data-name="@t.Name">
                                <div class="pc-img-wrap">
                                    <img src="@(!string.IsNullOrEmpty(t.ImagePath) ? t.ImagePath : "/uploads/softToys/Empty.png")"
                                         alt="@t.Name" class="pc-img" />
                                </div>
                                <div class="pc-body">
                                    <div class="pc-name">@t.Name</div>
                                    <div class="pc-desc">@t.Description</div>
                                    <div class="pc-footer">
                                        <span class="pc-price">@t.Price.ToString("C", culture)</span>
                                        <span class="pc-rating">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="#f5a623" stroke="#f5a623" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                            <p>@(t.Rating > 1 ? (t.Rating % 1 == 0 ? t.Rating.ToString("F0") : t.Rating.ToString("F1")) : "5")</p>
                                        </span>
                                    </div>
                                    <form method="post" asp-page-handler="AddProduct">
                                        <input type="hidden" name="SelectedProductId" value="@t.SoftToyId" />
                                        <input type="hidden" name="ProductType" value="softtoy" />
                                        <button type="submit" class="pc-add-btn">+ Добавить</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
