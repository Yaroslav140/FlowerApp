@page
@model FlowerShop.Web.Pages.Account.PlaceOrderModel

@section Styles {
    <link rel="stylesheet" href="/css/placeOrder.css" asp-append-version="true" />
}

<div class="order-center">
    <div class="order-card">
        <div class="header-order">
            <div class="icon-header">
                <img src="~/img/fly.png" alt="Delivery Icon" />
            </div>
            <h2>Оформить заказ</h2>
            <p>Заполните данные для доставки</p>
        </div>
        <div asp-validation-summary="ModelOnly" class="error"></div>

        <form method="post">
            <div class="form-group">
                <div class="header-hint">
                    <label asp-for="Phone">Номер телефона</label>
                    <p class="hint">
                        <span title="Номер связи с вами">?</span>
                    </p>
                </div>
                <input asp-for="Phone" class="form-control" placeholder="+7 (___) ___-__-__" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="header-hint">
                    <label asp-for="DeliveryAddress">Адрес доставки</label>
                    <p class="hint">
                        <span title="Адрес куда доставим вам заказ">?</span>
                    </p>
                </div>
                <input asp-for="DeliveryAddress" type="text" class="form-control" placeholder="Город, улица, дом, квартира" />
                <span asp-validation-for="DeliveryAddress" class="text-danger"></span>
            </div>

            <div class="form-group">
                <div class="header-hint">
                    <label asp-for="DeliveryDate">Дата и время доставки</label>
                    <p class="hint">
                        <span title="Время доставки на два часа позже текущего, чтобы мы успели собрать ваш заказ">?</span>
                    </p>
                </div>
                <input asp-for="DeliveryDate" type="datetime-local" class="form-control"
                       asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" />
                <span asp-validation-for="DeliveryDate" class="text-danger"></span>
            </div>

            <div class="order-summary">
                <div class="summary-info">
                    <strong>К оплате:</strong>
                </div>
                <div class="summary-total">
                    <span>@Model.TotalAmount</span>руб.
                </div>
            </div>

            <button asp-page-handler="SubmitOrder" type="submit" class="btn btn--brand">
                Отправить заказ
            </button>
        </form>
    </div>
</div>
